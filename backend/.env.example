# ─────────────────────────────────────────────
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Groq API Key — get free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (free options on Groq)
# Options: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama3-70b-8192

# HuggingFace embedding model (runs locally, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# FAISS index storage path
FAISS_INDEX_PATH=./storage/faiss_index

# Uploaded files storage path
UPLOAD_DIR=./storage/uploads

# Max file size in MB
MAX_FILE_SIZE_MB=50

# Chunk settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
